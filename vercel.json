{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/vt",          "destination": "/vt.html" },
    { "source": "/NT",          "destination": "/NT.html" },
    { "source": "/MissionJeet", "destination": "/MissionJeet.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN"  },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
