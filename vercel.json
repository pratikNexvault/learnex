{
  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },

    {
      "source": "/PW",
      "destination": "/PW.html"
    },

    {
      "source": "/NT",
      "destination": "/NT.html"
    },

    {
      "source": "/MissionJeet",
      "destination": "/MissionJeet.html"
    },

    {
      "source": "/vt",
      "destination": "/vt.html"
    },

    {
      "source": "/generate-main",
      "destination": "/generate-main.html"
    },

    {
      "source": "/generate-vibrant",
      "destination": "/generate-vibrant.html"
    },

    {
      "source": "/access",
      "destination": "/access.html"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
